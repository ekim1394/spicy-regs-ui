# @visx@3.12 pins its React peer to 16/17/18, but this project runs React 19.
# 3.12 is the latest @visx, so there's no version that lists React 19 — the
# peer range is just stale. The packages work fine on 19. Tell npm to proceed
# rather than erroring (ERESOLVE) on every install/update/ci.
legacy-peer-deps=true
